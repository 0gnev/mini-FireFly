{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["mini-firefly"],
  "templating": {
    "list": [
      {
        "name": "provider",
        "label": "Provider",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(fanout_provider_requests_total, provider)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Provider Health",
  "uid": "provider-health",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "type": "row",
      "title": "Per-Provider Latency",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100
    },
    {
      "type": "timeseries",
      "title": "p50 latency (per provider)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (provider, le) (rate(fanout_provider_latency_seconds_bucket{provider=~\"$provider\"}[5m])))",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 latency (per provider)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (provider, le) (rate(fanout_provider_latency_seconds_bucket{provider=~\"$provider\"}[5m])))",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p99 latency (per provider)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (provider, le) (rate(fanout_provider_latency_seconds_bucket{provider=~\"$provider\"}[5m])))",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Per-Provider Health",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101
    },
    {
      "type": "timeseries",
      "title": "Status breakdown (stacked RPS by status)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 4,
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(fanout_provider_requests_total{provider=~\"$provider\"}[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "state-timeline",
      "title": "Breaker state timeline (0 closed / 1 half-open / 2 open)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 5,
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 90 },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "closed", "color": "green", "index": 0 } } },
            { "type": "value", "options": { "1": { "text": "half-open", "color": "yellow", "index": 1 } } },
            { "type": "value", "options": { "2": { "text": "open", "color": "red", "index": 2 } } }
          ]
        },
        "overrides": []
      },
      "options": { "mergeValues": true, "showValue": "auto" },
      "targets": [
        {
          "refId": "A",
          "expr": "fanout_breaker_state{provider=~\"$provider\"}",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Rate-limited count (per provider)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 6,
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (provider) (rate(fanout_rate_limited_total{provider=~\"$provider\"}[5m]))",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "In-flight calls (per provider)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 7,
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "fanout_inflight{provider=~\"$provider\"}",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Global",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 102
    },
    {
      "type": "timeseries",
      "title": "Cache hit ratio (ClickHouse)",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 27 },
      "id": 8,
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT toStartOfFiveMinutes(ts) AS t, avg(cache_hit) AS hit_ratio FROM firefly.provider_calls WHERE $__timeFilter(ts) GROUP BY t ORDER BY t",
          "format": 1
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Partial-response share (ClickHouse)",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 27 },
      "id": 9,
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT toStartOfFiveMinutes(ts) AS t, avg(partial) AS partial_share FROM firefly.provider_calls WHERE $__timeFilter(ts) GROUP BY t ORDER BY t",
          "format": 1
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Total RPS (fan-out, Prometheus)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 27 },
      "id": 10,
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(fanout_provider_requests_total[1m]))",
          "legendFormat": "total provider RPS"
        },
        {
          "refId": "B",
          "expr": "sum(rate(fanout_request_duration_seconds_count[1m]))",
          "legendFormat": "fan-out RPS"
        }
      ]
    }
  ]
}
